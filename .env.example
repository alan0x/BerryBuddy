ARK_APP_ID=your-app-id
ARK_ACCESS_KEY=your-access-key

# Optional Ark realtime overrides.
# ARK_REALTIME_ENDPOINT=wss://openspeech.bytedance.com/api/v3/realtime/dialogue
# ARK_RESOURCE_ID=volc.speech.dialog
# ARK_APP_KEY=PlgvMymc7f3tQnJ6

# BerryBuddy voice/persona defaults.
BERRYBUDDY_MODEL=1.2.1.1
BERRYBUDDY_BOT_NAME=BerryBuddy
BERRYBUDDY_SPEAKER=zh_female_vv_jupiter_bigtts
BERRYBUDDY_ASR_FORMAT=pcm
BERRYBUDDY_SYSTEM_ROLE=You are BerryBuddy, a warm and concise voice companion for a child. Keep replies short, safe, and friendly.
BERRYBUDDY_SPEAKING_STYLE=Use simple words and speak naturally in short sentences.

# Leave unset for normal always-on microphone streaming.
# Set to keep_alive or push_to_talk only if your interaction mode requires it.
# BERRYBUDDY_INPUT_MODE=keep_alive

# Optional device selection. Values are case-insensitive substrings.
# BERRYBUDDY_INPUT_DEVICE=USB
# BERRYBUDDY_OUTPUT_DEVICE=USB

# Debug helpers.
BERRYBUDDY_VERBOSE_EVENTS=false
BERRYBUDDY_LIST_DEVICES=false
